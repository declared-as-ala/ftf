# FTF environment variables — copy to .env.local and fill in real values.
# NEVER commit real values. .env.local is gitignored.

# MongoDB connection string (Atlas or local replica set).
# MongoDB transactions require a replica set (Atlas provides one by default).
# Local dev against the docker-compose replica set:
#   MONGODB_URI=mongodb://localhost:27017/ftf?replicaSet=rs0&directConnection=true
MONGODB_URI=

# Base URL of the app.
NEXTAUTH_URL=http://localhost:3000

# JWT/session encryption secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

NODE_ENV=development
